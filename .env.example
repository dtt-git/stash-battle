# Copy this file to ".env" (which is gitignored) and fill in your local values.
# Used by scripts/build.mjs during `npm run dev`.

# Absolute path to YOUR local Stash "plugins" folder.
# On every dev rebuild, the plugin is deployed into <STASH_PLUGINS_DIR>/stash-battle.
# Leave unset (or set to "none") to skip deploying into Stash.
# Examples:
#   Windows:  STASH_PLUGINS_DIR=C:\Path\To\Stash\plugins
#   Linux:    STASH_PLUGINS_DIR=/home/you/.stash/plugins
#   macOS:    STASH_PLUGINS_DIR=/Users/you/.stash/plugins
STASH_PLUGINS_DIR=
